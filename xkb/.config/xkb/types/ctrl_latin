// Ctrl→Latin types for Russian layout
// When Ctrl is held, keys produce Latin (Group1-equivalent) characters
// while preserving the Ctrl modifier for applications.
//
// ALPHABETIC_CTRL: 4-level type for letter keys without AltGr overrides
//   Level1 = Cyrillic base, Level2 = Cyrillic Shift/Caps,
//   Level3 = Latin (Ctrl), Level4 = Latin uppercase (Ctrl+Shift)
//
// LEVEL3_CTRL: 6-level type for letter keys with AltGr overrides (UA/BE)
//   Level1-2 = Cyrillic, Level3-4 = AltGr (Right Alt),
//   Level5 = Latin (Ctrl), Level6 = Latin uppercase (Ctrl+Shift)

partial xkb_types "ctrl_latin" {

    type "ALPHABETIC_CTRL" {
        modifiers = Shift+Lock+Control;

        map[None] = Level1;
        map[Shift] = Level2;
        map[Lock] = Level2;
        map[Shift+Lock] = Level1;
        map[Control] = Level3;
        map[Shift+Control] = Level4;
        map[Control+Lock] = Level4;
        map[Shift+Control+Lock] = Level3;

        preserve[Control] = Control;
        preserve[Shift+Control] = Shift+Control;
        preserve[Control+Lock] = Control;
        preserve[Shift+Control+Lock] = Shift+Control;
    };

    type "LEVEL3_CTRL" {
        modifiers = Shift+Lock+LevelThree+Control;

        map[None] = Level1;
        map[Shift] = Level2;
        map[Lock] = Level2;
        map[Shift+Lock] = Level1;
        map[LevelThree] = Level3;
        map[Shift+LevelThree] = Level4;
        map[LevelThree+Lock] = Level4;
        map[Shift+LevelThree+Lock] = Level3;
        map[Control] = Level5;
        map[Shift+Control] = Level6;
        map[Control+Lock] = Level6;
        map[Shift+Control+Lock] = Level5;
        map[Control+LevelThree] = Level5;
        map[Shift+Control+LevelThree] = Level6;
        map[Control+LevelThree+Lock] = Level6;
        map[Shift+Control+LevelThree+Lock] = Level5;

        preserve[Control] = Control;
        preserve[Shift+Control] = Shift+Control;
        preserve[Control+Lock] = Control;
        preserve[Shift+Control+Lock] = Shift+Control;
        preserve[Control+LevelThree] = Control;
        preserve[Shift+Control+LevelThree] = Shift+Control;
        preserve[Control+LevelThree+Lock] = Control;
        preserve[Shift+Control+LevelThree+Lock] = Shift+Control;
    };

};
