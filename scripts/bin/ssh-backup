#!/usr/bin/env bash
set -euo pipefail

show_help() {
    cat <<EOF
Usage: ssh-backup [OPTIONS] [KEY_PATH]

Save one SSH key from disk to Vaultwarden as native SSH Key item (type 5).

Arguments:
  KEY_PATH              Path to SSH private key file (e.g. ~/.ssh/id_ed25519)

Options:
  --folder NAME     Folder name (default: "ssh keys", auto-created)
  --collection ID   Store in organization collection (requires --org)
  --org ID          Organization ID (required with --collection)
  --help            Show this help

If KEY_PATH is not provided, you will be prompted for it interactively.
EOF
    return 0 2>/dev/null || exit 0
}

COLLECTION_ID=""
ORG_ID=""
FOLDER_NAME="ssh keys"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --folder)      FOLDER_NAME="$2"; shift 2 ;;
        --collection)  COLLECTION_ID="$2"; shift 2 ;;
        --org)         ORG_ID="$2"; shift 2 ;;
        --help)        show_help ;;
        *)             KEY_PATH="${1:-}"; shift ;;
    esac
done

[[ -z "${BW_SESSION:-}" ]] && { echo "Error: BW_SESSION not set. Run: source vw-connect" >&2; exit 1; }
command -v jq &>/dev/null || { echo "Error: jq not found" >&2; exit 1; }
command -v bw &>/dev/null || { echo "Error: bw not found" >&2; exit 1; }
command -v ssh-keygen &>/dev/null || { echo "Error: ssh-keygen not found" >&2; exit 1; }

if [[ -z "${KEY_PATH:-}" ]]; then
    read -rp "Path to SSH private key: " KEY_PATH
fi

KEY_PATH="${KEY_PATH/#\~/$HOME}"

if [[ ! -f "$KEY_PATH" ]]; then
    echo "Error: file not found: $KEY_PATH" >&2
    exit 1
fi

if ! head -1 "$KEY_PATH" | grep -q "BEGIN"; then
    echo "Error: not a valid SSH private key: $KEY_PATH" >&2
    exit 1
fi

if ! ssh-keygen -y -P "" -f "$KEY_PATH" &>/dev/null; then
    echo "Error: key is passphrase-protected. Remove first: ssh-keygen -p -f $KEY_PATH" >&2
    exit 1
fi

PUBLIC_KEY=$(ssh-keygen -y -P "" -f "$KEY_PATH")
PRIVATE_KEY=$(cat "$KEY_PATH")
FILENAME=$(basename "$KEY_PATH")

read -rp "Item name (SSH alias, e.g. 'work'): " ITEM_NAME
if [[ -z "$ITEM_NAME" ]]; then
    echo "Error: item name is required" >&2
    exit 1
fi

read -rp "Host (leave empty for storage-only): " HOST
HOSTNAME_VAL=""
USER_VAL=""
PORT=""
EXTRA=""
IDENTITY_FILE="~/.ssh/$FILENAME"

if [[ -n "$HOST" ]]; then
    read -rp "HostName: " HOSTNAME_VAL
    read -rp "User: " USER_VAL
    read -rp "Port (leave empty for default): " PORT
    read -rp "Extra ssh-config options (leave empty): " EXTRA
fi

FIELDS=$(jq -n -c \
  --arg fn "$FILENAME" \
  --arg host "$HOST" \
  --arg hn "$HOSTNAME_VAL" \
  --arg user "$USER_VAL" \
  --arg port "$PORT" \
  --arg idfile "$IDENTITY_FILE" \
  --arg extra "$EXTRA" \
  '[
    {"name":"filename","value":$fn,"type":0},
    {"name":"Host","value":$host,"type":0},
    {"name":"HostName","value":$hn,"type":0},
    {"name":"User","value":$user,"type":0},
    {"name":"Port","value":$port,"type":0},
    {"name":"IdentityFile","value":$idfile,"type":0},
    {"name":"Extra","value":$extra,"type":0}
  ]')

if [[ -z "$HOST" ]]; then
    FIELDS=$(echo "$FIELDS" | jq 'map(select(.name != "Host" and .name != "HostName" and .name != "User" and .name != "Port" and .name != "Extra"))')
fi

ESCAPED_PRIV=$(printf '%s' "$PRIVATE_KEY" | jq -sR .)
ESCAPED_PUB=$(printf '%s' "$PUBLIC_KEY" | jq -sR .)

COLLECTION_ARGS=""
if [[ -n "$COLLECTION_ID" ]] && [[ -n "$ORG_ID" ]]; then
    COLLECTION_ARGS=", \"organizationId\": \"$ORG_ID\", \"collectionIds\": [\"$COLLECTION_ID\"]"
fi

FOLDER_ID=$(bw list folders --session "$BW_SESSION" 2>/dev/null | jq -r --arg f "$FOLDER_NAME" '.[] | select((.name | ascii_downcase) == ($f | ascii_downcase)) | .id' | head -1)
if [[ -z "$FOLDER_ID" ]]; then
    FOLDER_ID=$(jq -n -c --arg name "$FOLDER_NAME" '{name: $name}' | bw create folder --session "$BW_SESSION" 2>/dev/null | jq -r '.id')
fi

ESCAPED_PRIV=$(printf '%s' "$PRIVATE_KEY" | jq -sR .)
ESCAPED_PUB=$(printf '%s' "$PUBLIC_KEY" | jq -sR .)

ITEM_JSON=$(jq -n -c \
  --arg name "$ITEM_NAME" \
  --arg fid "$FOLDER_ID" \
  --argjson fields "$FIELDS" \
  "{type:5, name:\$name, folderId:\$fid, notes:\"\", secureNote:null, login:null, card:null, identity:null, sshKey:{privateKey:($ESCAPED_PRIV), publicKey:($ESCAPED_PUB)}, fields:\$fields, favorite:false, reprompt:0$COLLECTION_ARGS}")

ENCODED=$(printf '%s' "$ITEM_JSON" | base64 -w0)

EXISTING=$(bw list items --session "$BW_SESSION" 2>/dev/null | jq --arg n "$ITEM_NAME" -r '.[] | select(.name==$n) | .id' | head -1)

if [[ -n "$EXISTING" ]]; then
    read -rp "Item '$ITEM_NAME' already exists. Update? [y/N] " CONFIRM
    if [[ "${CONFIRM,,}" == "y" ]]; then
        printf '%s' "$ENCODED" | bw edit item "$EXISTING" --session "$BW_SESSION" >/dev/null
        echo "Updated '$ITEM_NAME' in VW"
    else
        echo "Skipped."
    fi
else
    printf '%s' "$ENCODED" | bw create item --session "$BW_SESSION" >/dev/null
    echo "Saved '$ITEM_NAME' to VW"
fi
