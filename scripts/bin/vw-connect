#!/usr/bin/env bash
set -euo pipefail

command -v bw >/dev/null || { echo "Error: bw CLI not found" >&2; exit 1; }
command -v jq >/dev/null || { echo "Error: jq not found" >&2; exit 1; }

show_help() {
    cat <<EOF
Usage: source vw-connect
       vw-connect [--url URL] [--email EMAIL]

Interactively connect to a Vaultwarden server.
Exports BW_SESSION when sourced.

Options:
  --url URL     Vaultwarden server URL
  --email EMAIL Login email
  --help        Show this help
EOF
    return 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --url)   VW_URL="$2"; shift 2 ;;
        --email) BW_EMAIL="$2"; shift 2 ;;
        --help)  show_help; [[ "${BASH_SOURCE[0]}" == "${0}" ]] && exit 0 || return 0 ;;
        *)       echo "Unknown option: $1" >&2; return 1 2>/dev/null || exit 1 ;;
    esac
done

if [[ -z "${VW_URL:-}" ]]; then read -rp "Vaultwarden URL: " VW_URL; fi
if [[ -z "${BW_EMAIL:-}" ]]; then read -rp "Email: " BW_EMAIL; fi
if [[ -z "${BW_PASS:-}" ]]; then read -s -rp "Master password: " BW_PASS; echo; fi

bw config server "$VW_URL" 2>/dev/null || true

BW_STATUS=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null || echo "unauthenticated")

case "$BW_STATUS" in
    unauthenticated)
        if ! BW_PASSWORD="$BW_PASS" bw login "$BW_EMAIL" --passwordenv BW_PASSWORD >/dev/null 2>&1; then
            echo "Error: login failed. Check email and password." >&2
            unset BW_PASS
            return 1 2>/dev/null || exit 1
        fi
        ;;
    locked) ;;
    unlocked) ;;
esac

export BW_SESSION=$(BW_PASSWORD="$BW_PASS" bw unlock --passwordenv BW_PASSWORD --raw 2>/dev/null)
unset BW_PASS

if [[ -z "${BW_SESSION:-}" ]]; then
    echo "Unlock failed. Enter master password:"
    export BW_SESSION=$(bw unlock --raw)
fi

if [[ -z "${BW_SESSION:-}" ]]; then
    echo "Error: failed to unlock vault" >&2
    return 1 2>/dev/null || exit 1
fi

bw sync --session "$BW_SESSION" >/dev/null
echo "Connected to VW at $VW_URL. BW_SESSION exported."
