# bootstrap.conf — copy to bootstrap.conf and edit before first run
# Empty values = prompted at runtime. Filled values = used silently.

# Personal data
GIT_NAME=""
GIT_EMAIL=""

# Vaultwarden (set URL to auto-configure during bootstrap)
VW_URL=""

# Bluetooth device MAC addresses (leave empty to auto-detect or skip)
BT_HEADPHONES=""
BT_MOUSE=""

# Modules to skip (uncomment to exclude)
# SKIP_MODULES=(xkb)

# Stop on first module failure (1 = abort, 0 = continue)
# STOP_ON_ERROR=0
