{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5.1",
  "default_agent": "0build",
  "autoupdate": true,
  "plugin": [
    "oh-my-openagent@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mystatus"
  ],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "agent": {
    "0build": {
      "mode": "primary",
      "description": "Full access agent for development work",
      "model": "zai-coding-plan/glm-5.1",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "0plan": {
      "mode": "primary",
      "description": "Planning and analysis agent without making changes",
      "model": "zai-coding-plan/glm-5.1",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "provider": {
    "zai-coding-plan": {
      "env": [
        "Z_AI_API_KEY"
      ],
      "models": {
        "glm-4.5": {
          "name": "GLM-4.5",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 98304
          }
        },
        "glm-4.5-air": {
          "name": "GLM-4.5-Air",
          "family": "glm-air",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 98304
          }
        },
        "glm-4.6": {
          "name": "GLM-4.6",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "glm-4.6v": {
          "name": "GLM-4.6V",
          "family": "glm",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "glm-5-turbo": {
          "name": "GLM-5-Turbo",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 131072
          }
        }
      }
    }
  },
  "mcp": {
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}"
      }
    },
    "zai-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "PLATFORM_MODE": "ZAI"
      }
    }
  },
  "shell": "tmux"
}
