        "opencode/nemotron-3-super-free",
        "opencode/gpt-5-nano"
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "zai-coding-plan": 10,
      "opencode": 10
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 401, 403, 429, 500, 502, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  }
}
